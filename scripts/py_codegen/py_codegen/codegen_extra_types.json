{
  "$schema": "proto_lib/TU.schema.json",
  "records": [
    {
      "name"              : {
        "spaces": [ {"name": "hstd"} ],
        "name"  : "Opt"
      },
      "reflection_params" : {
        "backend": {
          "target_backends": ["c"],
          "c"              : {
            "instantiation_mode"       : "void-handle",
            "value_template_parameters": ["T"]
          }
        }
      },
      "is_template_record": true,
      "templates"         : [
        {
          "stacks": [
            { "params": [ { "type_expr": {"name": "T"} } ] }
          ]
        }
      ],
      "methods"           : [
        {
          "name"             : "value",
          "return_ty"        : {
            "ref_kind": "LValue",
            "name": "T",
            "is_template_type_param": true,
            "qualifiers": [ {"is_const": true} ]
          },
          "reflection_params": {
            "backend": { "c": {"pointer_through_lambda": true} }
          }
        }
      ]
    }
  ]
}
