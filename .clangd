Hover:
  ShowAKA: Yes
Diagnostics:
  UnusedIncludes: Strict
  Suppress:
    - ext_pp_counter
CompileFlags:
  CompilationDatabase: build/haxorg_debug_qt/
  Add:
    - "-Wno-unknown-attributes"
    - "-Wno-unused-parameter"
    - "-Wno-extra-semi"
    - "-Wno-deprecated-copy"
    - "-Wno-pedantic"
    - "--log=verbose"
